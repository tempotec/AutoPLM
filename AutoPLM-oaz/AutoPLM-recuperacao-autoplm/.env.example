# ══════════════════════════════════════════════════════════
# AutoPLM — Environment Variables
# Copie este arquivo para .env e preencha os valores
# ══════════════════════════════════════════════════════════

# App
APP_ENV=production
SESSION_SECRET=GERAR_UMA_CHAVE_SECRETA_AQUI

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# OpenAI
OPENAI_API_KEY=sk-proj-...

# RPA Monitor
RPA_MONITOR_ID=APP-CATEGORIA-PRODUTO-OAZ
RPA_MONITOR_HOST=wss://appinsight.com.br/ws
RPA_MONITOR_REGION=Sudeste
RPA_MONITOR_TRANSPORT=ws

# Fluxogama / OAZ Integration
OAZ_BASE_URL=https://oaz.fluxogama.com.br/rest/api/v1
OAZ_CHAVE=TOKEN_JWT_INICIAL
OAZ_MODELO_SCHEMA_PATH=/remessa/modelo
OAZ_MODELO_PUSH_PATH=/remessa/modelo
OAZ_DEFAULT_COLECAO=GERAL
OAZ_USUARIO=Integracao.Oaz
OAZ_SENHA=1234
